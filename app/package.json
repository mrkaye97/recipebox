{
  "name": "recipebox",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "gen-schema": "curl localhost:8000/openapi.json > openapi.json && npx openapi-typescript --alphabetize --immutable openapi.json -o ./src/lib/api/v1.d.ts && rm openapi.json"
  },
  "dependencies": {
    "jwt-decode": "^4.0.0",
    "openapi-fetch": "^0.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "openapi-typescript": "^7.8.0",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.0"
  }
}
